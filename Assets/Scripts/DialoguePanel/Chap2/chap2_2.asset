  m_Script: {fileID: 11500000, guid: 3f100c39ea54d1945a1f135cd657088f, type: 3}
  m_Name: chap2_2
  m_EditorClassIdentifier: Assembly-CSharp::LevelStoryData
  levelName: 
  introLines:
  - speaker: ???
    text: "C\xF3 ai kh\xF4ng c\u1EE9u t\xF4i v\u1EDBi!!!"
  - speaker: Arin
    text: "H\u1EEDm ? Shadow mi c\xF3 nghe ti\u1EBFng ai k\xEAu c\u1EE9u kh\xF4ng
      v\u1EADy?"
  - speaker: Shadow
    text: "g\xE2u g\xE2u !"
  - speaker: Arin
    text: "H\xECnh nh\u01B0 \xE2m thanh k\xEAu c\u1EE9u \u0111\xF3 ng\xE0y c\xE0ng
      g\u1EA7n th\xEC  ph\u1EA3i\u2026 H\u1EEDm h\xECnh nh\u01B0 c\xF3 ng\u01B0\u1EDDi
      ch\u1EA1y \u0111\u1EBFn \u0111\xE2y\u2026 *nh\xECn r\xF5 h\u01A1n*. Shadow!!!
      L\xE0 ng\u01B0\u1EDDi s\u1ED1ng. N\xE0y!!! \u1EDF \u0111\xE2y mau t\u1EDBi
      \u0111\xE2y nhanh l\xEAn!!!"
  outroLines:
  - speaker: ???
    text: "K\u1EBFt\u2026 k\u1EBFt th\xFAc r\u1ED3i sao\u2026 C\u1EA3m.. c\u1EA3m
      \u01A1n c\u1EADu r\u1EA5t nhi\u1EC1u\u2026"
  - speaker: Arin
    text: "C\xF4 kh\xF4ng sao ch\u1EE9 , c\xF3 b\u1ECB l\xE0m sao kh\xF4ng ? C\u1EE9 
      b\xECnh t\u0129nh l\u1EA1i \u0111i k\u1EBFt th\xFAc r\u1ED3i\u2026 ch\u1EAFc 
      v\u1EADy"
  - speaker: Lena
    text: "T\xF4i\u2026 t\xF4i kh\xF4ng sao c\u1EA3m \u01A1n c\u1EADu nhi\u1EC1u\u2026
      T\xF4i t\xEAn l\xE0  Lena l\xE0\u2026 l\xE0 nh\xE0 nghi\xEAn c\u1EE9u sinh
      h\u1ECDc\u2026"
  - speaker: Arin
    text: "Nh\xE0 nghi\xEAn c\u1EE9u sinh h\u1ECDc sao ??? xin l\u1ED7i  t\xF4i h\u01A1i
      l\u1EDBn ti\u1EBFng r\u1ED3i , xin t\u1EF1 gi\u1EDBi thi\u1EC7u t\xF4i t\xEAn
      Arin v\xE0 \u0111\xE2y l\xE0 ng\u01B0\u1EDDi nh\xE0 c\u1EE7a t\xF4i Shadow"
  - speaker: Shadow
    text: "g\xE2u g\xE2u !"
  - speaker: Lena
    text: "v\xE2ng r\u1EA5t vui \u0111\u01B0\u1EE3c g\u1EB7p 2 ng\u01B0\u1EDDi\u2026
      *quan s\xE1t* n\u1EBFu t\xF4i \u0111o\xE1n kh\xF4ng nh\u1EA7m th\xEC ch\u1EAFc
      c\u1EADu \u0111ang c\xF3  nhi\u1EC1u c\xE2u  h\u1ECFi \u0111ang mu\u1ED1n h\u1ECFi
      t\xF4i l\u1EAFm nh\u1EC9. Nh\u01B0ng ph\u1EA3i n\xF3i v\u1EDBi c\u1EADu t\xF4i
      c\u0169ng  kh\xF4ng bi\u1EBFt g\xEC c\u1EA3 \u0111\xE2u\u2026Th\u1EE9 duy nh\u1EA5t
      t\xF4i bi\u1EBFt v\u1EC1 bon ch\xFAng l\xE0 ch\xFAng lu\xF4n ti\u1EBFn h\xF3a
      kh\xF4ng ng\u1EEBng ngh\u1EC9\u2026 nh\u01B0ng t\xF4i bi\u1EBFt m\u1ED9t n\u01A1i
      ch\u1EAFc h\u1EB3n s\u1EBD gi\xFAp ch\xFAng  ta bi\u1EBFt th\xEAm v\u1EC1 b\u1ECDn
      ch\xFAng\u2026"
  - speaker: Arin
    text: "c\xF4 bi\u1EBFt sao ??? \u1EDF n\u01A1i n\xE0o v\u1EADy ???"
  - speaker: Lena
    text: "v\u1EDBi t\xECnh c\u1EA3nh hi\u1EC7n t\u1EA1i c\xF3 n\xF3i n\u01A1i \u0111\xF3
      ra th\xEC ch\u1EAFc c\u1EADu c\u0169ng kh\xF4ng bi\u1EBFt v\u1ECB tr\xED n\xF3
      n\u1EB1m \u0111\xE2u \u0111\xE2u, t\xF4i s\u1EBD d\u1EABn c\u1EADu \u0111\u1EBFn
      n\u01A1i \u0111\xF3 , nh\u01B0ng c\u1EADu cho t\xF4i \u0111i c\xF9ng  \u0111\u01B0\u1EE3c
      kh\xF4ng\u2026?"
  - speaker: Arin
    text: "\u0110\u01B0\u1EE3c th\xF4i, mi\u1EC5n c\xF3 th\u1EC3 k\u1EBFt th\xFAc
      nh\u1EEFng con qu\xE1i v\u1EADt ch\u1EBFt ti\u1EC7t \u0111\xF3 l\xE0 \u0111\u01B0\u1EE3c
      r\u1ED3i"
