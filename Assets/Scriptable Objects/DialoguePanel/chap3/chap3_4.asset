  m_Script: {fileID: 11500000, guid: 3f100c39ea54d1945a1f135cd657088f, type: 3}
  m_Name: chap3_4
  m_EditorClassIdentifier: Assembly-CSharp::LevelStoryData
  levelName: 
  introLines:
  - speaker: Dr.Elias
    text: "v\u1EADt n\u1ED5 \u0111\xF3 n\u1EB1m s\xE2u trong c\u0103n c\u1EE9 qu\xE2n
      s\u1EF1 n\xE0y , \u0111\xF3 l\xE0 nh\u1EEFng v\u1EADt b\u1ECB b\u1ECF qu\xEAn
      , n\u01A1i m\xE0 ch\u1EC9 c\xF3 c\xE1c chi\u1EBFn binh n\u0103m x\u01B0a nh\u01B0
      t\xF4i m\u1EDBi bi\u1EBFt , t\xF4i s\u1EBD \u0111i \u0111\u1EBFn \u0111\xF3
      l\u1EA5y , c\u1EADu c\xF3 th\u1EC3 \u1EDF \u0111\xE2y gi\xFAp t\xF4i trong
      ch\u1EEBng n\u01A1i n\xE0y \u0111\u01B0\u1EE3c kh\xF4ng ?"
  - speaker: Aria
    text: "\u0111\u01B0\u1EE3c r\u1ED3i t\xF4i s\u1EBD trong ch\u1EEBng n\u01A1i
      n\xE0y th\u1EADt c\u1EA9n th\u1EADn"
  - speaker: Lena
    text: "T\xF4i s\u1EBD \u0111i c\xF9ng \xF4ng \u0111\u1EC3 v\u1EADn chuy\u1EC3n
      nh\u1EEFng th\u1EE9 \u0111\xF3 "
  outroLines:
  - speaker: Lena
    text: "b\u1ECDn t\xF4i quay tr\u1EDF v\u1EC1 r\u1ED3i \u0111\xE2y, c\u1EADu kh\xF4ng
      sao ch\u1EE9"
  - speaker: Arin
    text: "\u1ED4n nh\u01B0 ch\u01B0a t\u1EEBng \u0111\u01B0\u1EE3c \u1ED5n lu\xF4n.
      \u0110\u01B0\u1EE3c r\u1ED3i v\u1EDBi \u0111\u1ED1ng \u0111\xF3 ch\xFAng ta 
      s\u1EBD c\xF3 th\u1EC3 k\u1EBFt th\xFAc \u0111\u01B0\u1EE3c chuy\u1EC7n n\xE0y
      r\u1ED3i\u2026"
  - speaker: Shadow
    text: "G\xE2u G\xE2u G\xE2u G\xE2u!"
  - speaker: Dr.Elias
    text: "\u0110\u01B0\u1EE3c r\u1ED3i ngh\u1EC9 ng\u01A1i \u0111i , ta s\u1EBD
      d\u1EABn c\xE1c c\xF4 c\u1EADu \u0111\u1EBFn n\u01A1i \u0111\xF3 sau"
